# repomap-core environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# ── Dolt Database Connection ─────────────────────────────────────────
# Used by: .opencode/plugins/beads-cross-db-sync.ts, Dolt CLI tooling
# These should match .beads/config.yaml if you change them.
DOLT_HOST=127.0.0.1
DOLT_PORT=3307
DOLT_USER=root
DOLT_PASSWORD=

# ── Kilo Gateway ─────────────────────────────────────────────────────
# Auth is handled via OAuth device login, not an API key.
# Run `kilo auth login` once to authenticate (select "Kilo Gateway").
# Credentials are stored in ~/.local/share/kilo/auth.json.
# This enables Anthropic prompt caching (~95% cost reduction).

# ── Optional: MCP Server Authentication ──────────────────────────────
# SONARQUBE_TOKEN=        # SonarQube MCP server (code quality metrics)
# CONTEXT7_API_KEY=       # Context7 MCP server (library docs lookup)

# ── Experimental (not required for repomap-core) ─────────────────────
# OPENROUTER_API_KEY=     # OpenRouter API (claims extension, not core)
